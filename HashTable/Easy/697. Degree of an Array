class Solution {
public:
    int findShortestSubArray(vector<int>& nums) {
       int maxfreq=0;
       unordered_map<int,int> freq;
       for(int x:nums){
            freq[x]++;
            maxfreq = max(maxfreq , freq[x]);
        }
        int ans = INT_MAX;
        for(auto& it : freq){
            if(it.second == maxfreq){

                int first =-1,last=-1;
                for(int i=0;i<nums.size();i++){
                    if(nums[i]==it.first){
                        if(first==-1){
                            first = i;
                        }
                        last=i;
                    }
                }
                ans = min(ans,last-first+1);
            }
        }
        return ans;
    }
};