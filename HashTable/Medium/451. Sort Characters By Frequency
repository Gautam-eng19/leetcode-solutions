class Solution {
public:
    string frequencySort(string s) {

        unordered_map<char, int> freq;

        for (char c : s)
            freq[c]++;

        vector<vector<char>> bucket(s.size() + 1);

        for (auto &it : freq)
            bucket[it.second].push_back(it.first);

        string ans;

        for (int f = s.size(); f >= 1; f--) {

            for (char c : bucket[f]) {

                ans += string(f, c);

            }

        }

        return ans;
    }
};