    class Solution {
public:
    vector<int> selfDividingNumbers(int left, int right) {
        vector<int> ans;
        for(int i = left;i<=right;i++){
            int num =i;
            int digit=0;
            while(num>0){
                digit = num%10;
                if(digit==0){
                    break;
                }
                if(i%digit!=0){
                    break;
                }
                num/=10;
            }
            if(num<=0){
                ans.push_back(i);
            }
        }
        return ans;
    }
};