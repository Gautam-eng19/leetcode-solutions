class Solution {
public:
    double averageWaitingTime(vector<vector<int>>& customers) {
        long long time=customers[0][0],waiting=0;
        int n = customers.size();
        for(int i=0;i<customers.size();i++){
            int arrivalTime = customers[i][0];
            int PrepTime = customers[i][1];
            time = max(time,(long long)arrivalTime);
            time+=PrepTime;
            if(i==0){
                waiting += PrepTime;
            }
            else{
                waiting+=time - arrivalTime;
            }
                
            
        }
        return (double)waiting/n;
    }
};