class Solution {
public:
    int countDistinctIntegers(vector<int>& nums) {
        int count=0;
        int size = nums.size();
        for(int i = 0 ; i<size ; i++){
            int rev = 0;
            int n = nums[i];
            while (n > 0) {
                rev = rev * 10 + n % 10;
                n /= 10;
            }
            nums.push_back(rev);
        }

        unordered_set<int> s (nums.begin(),nums.end());
        return s.size();
    }
};