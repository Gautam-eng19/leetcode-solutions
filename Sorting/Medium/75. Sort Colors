class Solution {
public:
    void sortColors(vector<int>& nums) {
        int n = nums.size();
        unordered_map<int,int> map;
        for(int i =0;i<n;i++){
            map[nums[i]]++;
        }
        int j=0;
        while(map[0]){
            nums[j++]=0;
            map[0]--;
        }
        while(map[1]){
            nums[j++]=1;
            map[1]--;
        }
        while(map[2]){
            nums[j++]=2;
            map[2]--;
        }
    }
};