class Solution {
public:
    static bool compare(string a , string b){
        return a+b>b+a;
    }
    string largestNumber(vector<int>& nums) {
        string ans ="";
        vector<string> arr;
        for(int x:nums){
            arr.push_back(to_string(x));
        }

        sort(arr.begin(),arr.end(),compare);

        if(arr[0]=="0") return "0";
        for(string s : arr){
            ans+=s;
        }
        return ans;
    }
};