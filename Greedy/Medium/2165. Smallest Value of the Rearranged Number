class Solution {
public:
    long long smallestNumber(long long num) {
        if(num==0) return 0;
        long long n = abs(num);
        vector<int> arr;
        while(n>0){
            arr.push_back(n%10);
            n/=10;
        }
        if(num>=0){
            sort(arr.begin(),arr.end());
            for(int i = 0; i < arr.size(); i++){
                if(arr[i] != 0){
                    swap(arr[0], arr[i]);
                    break;
                }
            }
        }else{
            sort(arr.begin(),arr.end(),greater<int>());
        }
        long long ans=0;
        for(int i = 0 ; i<arr.size();i++){
            ans = (ans*10)+arr[i];
        }
        return num>0?ans:-ans;
    }
};