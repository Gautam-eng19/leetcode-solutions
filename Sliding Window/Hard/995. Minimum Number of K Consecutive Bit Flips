class Solution {
public:
    int minKBitFlips(vector<int>& nums, int k) {
        int n = nums.size();
        int flipcount=0;
        int ans = 0;
        vector<int> flipped(n,0);

        for(int i=0;i<n;i++){
            if(i>=k){
                flipcount-=flipped[i-k];
            }
            
            if(flipcount%2==1){
                nums[i]^=1;
            }
            if(nums[i]==0){
                if(i+k>n){
                    return -1;
                }
                flipped[i]=1;
                flipcount++;
                ans++;
            }
        }

        return ans;
    }
};