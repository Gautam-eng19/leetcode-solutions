class Solution {
public:
    int maximumUniqueSubarray(vector<int>& nums) {
        int l=0,r=0,sum=0,ans=0;
        unordered_map<int,int> mpp;
        while(r<nums.size()){
            mpp[nums[r]]++;
            sum+=nums[r];
            while(mpp[nums[r]]>1){
                mpp[nums[l]]--;
                sum-=nums[l];
                l++;
            }
            ans= max(ans,sum);
            r++;
        }
        return ans;
    }
};