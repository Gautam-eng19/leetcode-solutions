class Solution {
public:
    int numOfSubarrays(vector<int>& arr, int k, int threshold) {
        int n = arr.size();
        int count = 0;
        long long sum = 0;
        
        for (int i = 0; i < k; i++){
            sum += arr[i];
        }
        if (sum >= 1LL * k * threshold){
            count++;
        }
        for (int i = k; i < n; i++){
            sum += arr[i];
            sum -= arr[i - k];
            
            if(sum >= 1LL * k * threshold){
                count++;
            }
        }
        
        return count;
    }
};