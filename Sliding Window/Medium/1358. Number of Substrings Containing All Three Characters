class Solution {
public:
    int numberOfSubstrings(string s) {
        int lastscene[3] = {-1,-1,-1};
        int count=0;
        for(int i =0 ; i<s.size() ; i++){
            lastscene[s[i] - 'a'] = i;
            if(lastscene[0]!=-1 &&lastscene[1]!=-1 &&lastscene[2]!=-1 ){
                count= count+ 1+ min({lastscene[0] , lastscene[1] , lastscene[2]});
            }
        }   
        return count;
    }
};