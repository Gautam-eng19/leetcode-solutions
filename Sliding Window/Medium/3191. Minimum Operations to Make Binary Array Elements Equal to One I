class Solution {
public:
    int minOperations(vector<int>& nums) {
        int l=0,r=2,count=0;
        int n =nums.size();
        while(r<n){
            if(nums[l]==0){
                nums[l]=!nums[l];
                nums[l+1]=!nums[l+1];
                nums[r]=!nums[r];
                count++;
            }
            if(r==n-1){
                if(nums[l]!=1||nums[l+1]!=1||nums[r]!=1){
                    return -1;
                }
            }
            l++;
            r++;
        }
        return count;
    }
};