class Solution {
public:
    int atMost(vector<int>& nums ,int k){
        if(k<0) return 0;
        int freq =0;
        int n = nums.size(),count=0;
        int l=0,r=0;
        while(r<n){
            if(nums[r]%2!=0){
                freq++;
            }
            while(freq>k){
                if(nums[l]%2!=0){
                    freq--;
                }
                l++;
                
            }
            count+=(r-l+1);
            r++;
            

        }
        return count;
    }

    int numberOfSubarrays(vector<int>& nums, int k) {
        return atMost(nums, k) - atMost(nums, k - 1);
    }
};