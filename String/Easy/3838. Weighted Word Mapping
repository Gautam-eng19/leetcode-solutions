class Solution {
public:
    string mapWordWeights(vector<string>& words, vector<int>& weights) {
        string final="";
        unordered_map<char,int> map;
        for(int i=0;i<26;i++){
            map['a'+i]=weights[i];
        }

        for(int i=0;i<words.size();i++){
            int sum=0;
            for(int j=0;j<words[i].size();j++){
                char ch = words[i][j];
                sum+=map[ch];
            }
            int temp = sum%26;
            final+=('z'-temp);
        }
        return final;
    }
};